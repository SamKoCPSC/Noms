# Local development environment variables
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local

# PostgreSQL (local Docker)
# Used by pgmold and the application to connect to the database
DATABASE_URL=postgres://noms:noms_local_pass@localhost:5432/noms

# R2 / S3 storage (local MinIO)
# Used for media file uploads during development
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=noms-local-key
R2_SECRET_ACCESS_KEY=noms-local-secret
R2_ACCOUNT_ID=placeholder-account-id
R2_BUCKET=noms-media

# Google OAuth (local mock server)
# Pointed at the local mock OAuth server for development
GOOGLE_AUTH_URL=http://localhost:8082/authorize
GOOGLE_TOKEN_URL=http://localhost:8082/token
GOOGLE_USERINFO_URL=http://localhost:8082/userinfo
GOOGLE_CLIENT_ID=google
GOOGLE_CLIENT_SECRET=secret

# GitHub OAuth (local mock server)
# Pointed at the local mock OAuth server for development
GITHUB_AUTH_URL=http://localhost:8082/authorize
GITHUB_TOKEN_URL=http://localhost:8082/token
GITHUB_CLIENT_ID=github
GITHUB_CLIENT_SECRET=secret

# Apple OAuth (local mock server)
# Pointed at the local mock OAuth server for development
# Apple-specific fields can be left empty for local mock testing
APPLE_AUTH_URL=http://localhost:8082/authorize
APPLE_TOKEN_URL=http://localhost:8082/token
APPLE_SERVICES_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Session cookie signing
# Must be a random string. Use a secure random value in production!
SESSION_SECRET=change-me-in-production-use-rust-random-uuid
