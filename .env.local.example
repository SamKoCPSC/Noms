# Local development environment variables
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local

# PostgreSQL (local Docker) — used by sqlx (DATABASE_URL) and pgschema (PG* vars)
DATABASE_URL=postgres://noms:noms_local_pass@localhost:5432/noms

# Individual PostgreSQL connection parameters — used by pgschema
# These must match the components of DATABASE_URL above.
PGHOST=localhost
PGPORT=5432
PGDATABASE=noms
PGUSER=noms
PGPASSWORD=noms_local_pass

# R2 / S3 storage (local MinIO)
# Used for media file uploads during development
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=noms-local-key
R2_SECRET_ACCESS_KEY=noms-local-secret
R2_ACCOUNT_ID=placeholder-account-id
R2_BUCKET=noms-media

# Google OAuth
GOOGLE_CLIENT_ID=google
GOOGLE_CLIENT_SECRET=secret

# GitHub OAuth
GITHUB_CLIENT_ID=github
GITHUB_CLIENT_SECRET=secret
GITHUB_USERINFO_URL=http://localhost:8082/userinfo

# Apple-specific fields can be left empty for local mock testing
APPLE_SERVICES_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Session cookie signing
# Must be a random string. Use a secure random value in production!
SESSION_SECRET=change-me-in-production-use-rust-random-uuid

# Cookie domain (optional)
# Set to restrict the session cookie to a specific domain and its subdomains.
# Example: .example.com (note the leading dot for subdomain inclusion)
# Leave empty or unset to use the default behavior (cookie scoped to current host)
# COOKIE_DOMAIN=.example.com